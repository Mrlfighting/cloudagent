FROM python:3.10-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONPATH=/workspace/app:/workspace/agent

WORKDIR /workspace

COPY agent/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt fastapi "uvicorn[standard]"

COPY app ./app
COPY agent ./agent
COPY alembic.ini ./alembic.ini
COPY migrations ./migrations

EXPOSE 5000
CMD ["sh", "-c", "python -m alembic upgrade head && cd /workspace/app && uvicorn app_main:app --host 0.0.0.0 --port 5000"]